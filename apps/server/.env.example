# rs-wallet 环境配置
# 复制为 .env 并根据实际环境修改

# 数据库连接
DATABASE_URL=postgresql://imwallet:CHANGE_ME@localhost:5432/imwallet

# HTTP 服务端口
PORT=3000

# 环境标识
ENVIRONMENT=development

# 费率配置（默认值，可在数据库中 app_configs 表覆盖）
FEE_RATE=0.005
FEE_MODE=DEDUCTED

# 交易限制（可被数据库 app_configs 覆盖）
TX_RESTRICT_WALLET=true

# 服务配置密码（用于进入配置管理页面）
SERVER_PWD=CHANGE_ME

# 签名时间戳窗口（秒）
TIMESTAMP_WINDOW_SECS=300

# Nonce 防重放缓存大小
NONCE_CACHE_CAPACITY=100000