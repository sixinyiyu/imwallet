# Server
PORT=3000
NODE_ENV=production

# Database (PostgreSQL on AWS RDS)
DATABASE_URL=postgresql://user:password@your-rds-endpoint.region.rds.amazonaws.com:5432/imwallet

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# RSA Keys (generate with: ssh-keygen -t rsa -b 2048 -m PEM)
# Set these in production to keep keys persistent across container restarts
# RSA_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----
# RSA_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----

# Seed password (for initial admin user)
SEED_PASSWORD=your_seed_password_here

# Fee
FEE_RATE=0.005
FEE_MODE=DEDUCTED