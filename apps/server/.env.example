# rs-wallet 环境变量示例
# 复制此文件为 .env 并填入真实值
# 优先级：环境变量 > config.toml

# ── 必填 ──
DATABASE_URL=postgresql://imwallet:your_password@localhost:5432/imwallet

# ── 服务配置密码（⚠️ 务必修改，勿提交真实密码） ──
SERVER_PWD=your_service_password

# ── 可选覆盖 ──
PORT=3000
RSA_PRIVATE_KEY_PATH=keys/rsa_private.pem
RSA_PUBLIC_KEY_PATH=keys/rsa_public.pem

# ── CORS 跨域来源（目前仅通过 config.toml [cors] 配置，不支持环境变量覆盖） ──
# 如需修改跨域白名单，请编辑 config.toml 中的 [cors].allowed_origins
