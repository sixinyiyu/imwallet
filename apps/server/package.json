{
  "name": "@imwallet/server",
  "version": "1.0.3",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "node prisma/seed.js",
    "db:seed:sql": "sh -c 'psql \"$DATABASE_URL\" -v seed_password=\"'\\''$SEED_PASSWORD'\\''\" -f prisma/seed.sql'"
  },
  "dependencies": {
    "@noble/ed25519": "^3.1.0",
    "@prisma/client": "^6.5.0",
    "bcrypt": "^5.1.1",
    "bip39": "^3.1.0",
    "bitcoinjs-lib": "^7.0.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "ecpair": "^3.0.1",
    "ethers": "^6.16.0",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "express-validator": "^7.2.1",
    "hdkey": "^2.1.0",
    "jsonwebtoken": "^9.0.2",
    "tiny-secp256k1": "^2.2.4",
    "tronweb": "^6.3.0",
    "uuid": "^11.1.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/hdkey": "^2.1.0",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.13.0",
    "@types/uuid": "^10.0.0",
    "eslint": "^9.20.0",
    "prisma": "^6.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.3",
    "vitest": "^3.1.1"
  }
}
