{
  "name": "@imwallet/server",
  "version": "1.0.8",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "db:generate": "prisma generate",
    "db:init": "node -e \"const{PrismaClient}=require('@prisma/client');const p=new PrismaClient();const fs=require('fs');const{splitSql}=require('./dist/services/sqlSplitter');const sql=fs.readFileSync('prisma/init.sql','utf-8');const stmts=splitSql(sql);Promise.all(stmts.map(s=>p.$executeRawUnsafe(s))).then(()=>{console.log('DB initialized');p.$disconnect()}).catch(e=>{console.error(e);p.$disconnect();process.exit(1)})\""
  },
  "dependencies": {
    "@noble/ed25519": "^3.1.0",
    "@prisma/client": "^6.5.0",
    "bcryptjs": "^3.0.3",
    "bip39": "^3.1.0",
    "bitcoinjs-lib": "^7.0.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "ecpair": "^3.0.1",
    "ethers": "^6.16.0",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "express-validator": "^7.2.1",
    "hdkey": "^2.1.0",
    "jsonwebtoken": "^9.0.2",
    "tiny-secp256k1": "^2.2.4",
    "tronweb": "^6.3.0",
    "uuid": "^11.1.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/hdkey": "^2.1.0",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.13.0",
    "@types/uuid": "^10.0.0",
    "eslint": "^9.20.0",
    "prisma": "^6.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.3",
    "vitest": "^3.1.1"
  }
}