generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "rhel-openssl-3.0.x", "windows"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// 钱包来源：CREATE=新建钱包, IMPORT=导入钱包
enum WalletSource {
  IMPORT
  CREATE
}

/// 交易状态：PENDING=待确认, CONFIRMED=已确认, FAILED=失败
enum TxStatus {
  PENDING
  CONFIRMED
  FAILED
}

/// 通知类型
enum NotificationType {
  TRANSFER_IN
  TRANSFER_OUT
}


enum Platform {
  ios
  android
  web
}

/// 设备商店来源
enum PlatformStore {
  appStore
  googlePlay
  fdroid
}

/// 设备表：存储设备信息，设备标识 = Ed25519 公钥 hex
model Device {
  id           Int       @id @default(autoincrement())
  /// 设备标识，Ed25519 公钥 hex（64字符），客户端生成的密钥对公钥
  device_id    String    @unique @db.VarChar(64)
  /// 设备平台：ios/android/web
  platform     Platform
  /// 商店来源：appStore/googlePlay/fdroid/null（web平台为null）
  platform_store PlatformStore? @map("platform_store")
  /// 操作系统版本
  os           String?   @db.VarChar(32)
  /// 设备型号
  model        String?   @db.VarChar(64)
  /// 语言/地区设置
  locale       String?   @db.VarChar(16)
  /// App 版本号
  version      String?   @db.VarChar(32)
  /// 法币货币代码
  currency     String?   @db.VarChar(8)
  /// Push 推送 token
  token        String?   @db.VarChar(256)
  /// 是否启用推送通知
  is_push_enabled Boolean @default(false) @map("is_push_enabled")
  /// 是否启用价格提醒
  is_price_alerts_enabled Boolean @default(false) @map("is_price_alerts_enabled")
  /// 订阅版本号，用于增量同步
  subscriptions_version Int? @default(0) @map("subscriptions_version")
  created_at   DateTime  @default(now()) @map("created_at")
  updated_at   DateTime  @updatedAt @map("updated_at")

  walletSubscriptions WalletSubscription[]
  contacts           Contact[]
  notificationReadStatuses NotificationRead[]

  @@map("devices")
}

/// 代币表：存储系统支持的代币类型
model Token {
  id              String    @id @default(uuid())
  /// 代币符号，如 USDT、TRX
  symbol          String    @unique @db.VarChar(16)
  /// 代币名称，如 Tether USD、Tron
  name            String    @db.VarChar(64)
  /// 精度（小数位数）
  decimals        Int       @default(6)
  /// 所属网络
  network         String    @default("Private Chain") @db.VarChar(64)
  /// 合约地址（可选，原生代币为空）
  contractAddress String?   @map("contract_address") @db.VarChar(66)
  /// 图标 URL（可选）
  iconUrl         String?   @map("icon_url") @db.VarChar(512)
  /// 是否启用
  isActive        Boolean   @default(true) @map("is_active")
  /// 是否可创建账户：原生代币=true，度量币(USDT)=false
  isAccountToken  Boolean   @default(true) @map("is_account_token")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  walletTokens    WalletToken[]
  transactions    Transaction[]

  @@map("tokens")
}

/// 钱包表：存储用户创建或导入的钱包
model Wallet {
  id           String        @id @default(uuid())
  /// 钱包标识，aqud + 32位Base62随机字符串，全局唯一
  identifier   String        @unique @db.VarChar(36)
  /// 钱包别名，用户自定义名称
  alias        String        @db.VarChar(64)
  /// 钱包地址，链上唯一标识（兼容旧数据，新钱包使用Account地址）
  address      String        @unique @db.VarChar(64)
  /// 钱包来源
  source       WalletSource  @default(CREATE)
  /// 钱包密码（bcrypt hash），用于备份、删除等敏感操作的验证
  password      String        @db.VarChar(128)
  /// 密码提示，帮助用户回忆密码
  passwordHint  String?       @map("password_hint") @db.VarChar(128)
  /// 备注说明
  memo         String        @default("") @db.VarChar(256)
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  accounts     Account[]
  sentTxs      Transaction[] @relation("FromWallet")
  receivedTxs  Transaction[] @relation("ToWallet")
  tokenBalances WalletToken[]
  subscriptions WalletSubscription[]
  notifications  Notification[]

  @@map("wallets")
}

/// 钱包代币余额表：每个钱包中每种代币的余额（兼容旧数据）
model WalletToken {
  id        String   @id @default(uuid())
  walletId  String   @map("wallet_id") @db.VarChar(36)
  tokenId   String   @map("token_id") @db.VarChar(36)
  /// 代币余额
  balance   Decimal  @default(0) @db.Decimal(30, 8)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)
  token  Token  @relation(fields: [tokenId], references: [id], onDelete: Cascade)

  @@unique([walletId, tokenId])
  @@map("wallet_tokens")
}

/// 账户表：钱包下的区块链网络账户，每个钱包每个网络一个账户
model Account {
  id        String   @id @default(uuid())
  walletId  String   @map("wallet_id") @db.VarChar(36)
  /// 所属网络（如 Tron、Ethereum）
  network   String   @db.VarChar(64)
  /// 账户名称
  name      String   @db.VarChar(64)
  /// 链上地址（Tron格式: T+33位随机字符）
  address   String   @db.VarChar(64)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@unique([walletId, network])
  @@map("accounts")
}

/// 钱包-设备订阅关联表：多对多关系
model WalletSubscription {
  id         Int      @id @default(autoincrement())
  /// 钱包 ID
  wallet_id  String   @db.VarChar(36)
  /// 设备 ID（devices 表的自增主键）
  device_id  Int
  /// 链标识（预留）
  chain      String?  @db.VarChar(32)
  /// 地址标识（预留）
  address_id String?  @db.VarChar(36)
  created_at DateTime @default(now()) @map("created_at")

  wallet Wallet @relation(fields: [wallet_id], references: [id], onDelete: Cascade)
  device Device @relation(fields: [device_id], references: [id], onDelete: Cascade)

  @@unique([wallet_id, device_id, chain, address_id])
  @@map("wallet_subscriptions")
}

/// 法币汇率表：存储各法币对 USDT 的兑换汇率
model FiatCurrency {
  id       String   @id @default(uuid())
  /// 货币代码，如 USD、CNY、EUR
  code     String   @unique @db.VarChar(8)
  /// 货币名称，如 US Dollar、人民币
  name     String   @db.VarChar(32)
  /// 货币符号，如 $、¥、€
  symbol   String   @db.VarChar(4)
  /// 对 USDT 的汇率
  rate     Decimal  @db.Decimal(18, 8)
  /// 小数位数
  decimals Int      @default(2)
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("fiat_currencies")
}

/// 交易记录表：存储钱包间的转账记录
model Transaction {
  id           String   @id @default(uuid())
  /// 交易哈希，链上唯一标识
  txHash       String   @unique @map("tx_hash") @db.VarChar(66)
  /// 付款钱包 ID
  fromWalletId String   @map("from_wallet_id") @db.VarChar(36)
  /// 收款钱包 ID
  toWalletId   String   @map("to_wallet_id") @db.VarChar(36)
  /// 代币 ID
  tokenId      String   @map("token_id") @db.VarChar(36)
  /// 交易金额
  amount       Decimal  @db.Decimal(30, 8)
  /// 手续费
  fee          Decimal  @default(0) @db.Decimal(30, 8)
  /// 交易状态
  status       TxStatus @default(PENDING)
  /// 交易备注
  memo         String   @default("") @db.VarChar(256)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  fromWallet Wallet @relation("FromWallet", fields: [fromWalletId], references: [id])
  toWallet   Wallet @relation("ToWallet", fields: [toWalletId], references: [id])
  token      Token  @relation(fields: [tokenId], references: [id])

  @@map("transactions")
}

/// 地址本：常用联系人地址表
model Contact {
  id        String   @id @default(uuid())
  /// 设备 ID（devices 表的自增主键）
  device_id Int
  /// 联系人名称
  name      String   @db.VarChar(64)
  /// 链上地址（Account.address，如 T.../0x.../1...）
  address   String   @db.VarChar(64)
  /// 链类型（TRON/EVM/BTC 等）
  network   String   @db.VarChar(64)
  /// 备注
  memo      String   @default("") @db.VarChar(256)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  device Device @relation(fields: [device_id], references: [id], onDelete: Cascade)

  @@map("contacts")
}

/// 通知/消息表：站内信通知（关联到钱包）
model Notification {
  id        String           @id @default(uuid())
  /// 关联钱包 ID
  wallet_id String           @map("wallet_id") @db.VarChar(36)
  /// 通知标题
  title     String           @db.VarChar(128)
  /// 通知内容
  content   String           @db.Text
  /// 通知类型
  type      NotificationType @map("type")
  createdAt DateTime         @default(now()) @map("created_at")

  wallet Wallet @relation(fields: [wallet_id], references: [id], onDelete: Cascade)
  readStatuses NotificationRead[]

  @@map("notifications")
}

/// 通知阅读状态：每个设备对每条通知的独立阅读状态
model NotificationRead {
  id              Int      @id @default(autoincrement())
  notification_id String   @map("notification_id")
  device_id       Int      @map("device_id")
  /// 是否已读
  isRead          Boolean  @default(false) @map("is_read")
  /// 阅读时间
  readAt          DateTime? @map("read_at")
  created_at      DateTime @default(now()) @map("created_at")

  notification Notification @relation(fields: [notification_id], references: [id], onDelete: Cascade)
  device       Device      @relation(fields: [device_id], references: [id], onDelete: Cascade)

  @@unique([notification_id, device_id])
  @@map("notification_reads")
}