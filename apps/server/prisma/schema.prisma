generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "rhel-openssl-3.0.x", "windows"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// 钱包来源：CREATE=新建钱包, IMPORT=导入钱包
enum WalletSource {
  IMPORT
  CREATE
}

/// 交易状态：PENDING=待确认, CONFIRMED=已确认, FAILED=失败
enum TxStatus {
  PENDING
  CONFIRMED
  FAILED
}

/// 通知类型
enum NotificationType {
  TRANSFER_IN
  TRANSFER_OUT
}


enum Platform {
  ios
  android
  web
}

/// 设备表：存储设备信息，设备标识 = Ed25519 公钥 hex
model Device {
  id           Int       @id @default(autoincrement())
  /// 设备标识，Ed25519 公钥 hex（64字符），客户端生成的密钥对公钥
  device_id    String    @unique @db.VarChar(64)
  /// 设备平台：ios/android/web
  platform     Platform
  /// 商店来源：appStore/googlePlay/fdroid（web平台为空字符串）
  platform_store String    @default("") @map("platform_store") @db.VarChar(16)
  /// 操作系统版本
  os           String    @default("") @db.VarChar(32)
  /// 设备型号
  model        String    @default("") @db.VarChar(64)
  /// 语言/地区设置
  locale       String    @default("") @db.VarChar(16)
  /// App 版本号
  version      String    @default("") @db.VarChar(32)
  /// 法币货币代码
  currency     String    @default("") @db.VarChar(8)
  /// Push 推送 token
  token        String    @default("") @db.VarChar(256)
  /// 是否启用推送通知
  is_push_enabled Boolean @default(false) @map("is_push_enabled")
  /// 是否启用价格提醒
  is_price_alerts_enabled Boolean @default(false) @map("is_price_alerts_enabled")
  /// 订阅版本号，用于增量同步
  subscriptions_version Int @default(0) @map("subscriptions_version")
  created_at   DateTime  @default(now()) @map("created_at")
  updated_at   DateTime  @updatedAt @map("updated_at")

  @@map("devices")
}

/// 链表：存储系统支持的区块链网络
model Chain {
  id                  Int      @id @default(autoincrement())
  /// 链名称，如 Tron、Ethereum、Bitcoin
  name                String   @unique @db.VarChar(64)
  /// 显示名称
  displayName         String   @map("display_name") @db.VarChar(64)
  /// 是否支持创建账户（派生链地址）
  accountEnable      Boolean  @default(true) @map("account_enable")
  /// BIP44 派生路径前缀，如 m/44'/195'/0'/0
  derivationPath      String   @default("") @map("derivation_path") @db.VarChar(128)
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@map("chains")
}

/// 资产表：定义每条链支持的资产（原生币/代币）
model Asset {
  id              String    @id @default(uuid())
  /// 资产符号，如 TRX、USDT、ETH、BTC
  symbol          String    @db.VarChar(16)
  /// 资产名称，如 Tether USD、Tron
  name            String    @db.VarChar(64)
  /// 精度（小数位数）
  decimals        Int       @default(6)
  /// 所属链（如 Tron、Ethereum、Bitcoin）
  chain           String    @db.VarChar(64)
  /// 资产类型：NATIVE=原生主币, TOKEN=代币(ERC20/TRC20)
  type            String    @default("NATIVE") @db.VarChar(16)
  /// 合约地址（NATIVE为空字符串，TOKEN为合约地址）
  tokenId         String   @default("") @map("token_id") @db.VarChar(66)
  /// 图标 URL
  iconUrl         String   @default("") @map("icon_url") @db.VarChar(512)
  /// 是否默认可见（NATIVE=true，常见代币=true，其他需手动添加）
  isDefault       Boolean   @default(true) @map("is_default")
  /// 是否启用
  isActive        Boolean   @default(true) @map("is_active")
  /// 是否支持交易
  isTradable      Boolean   @default(true) @map("is_tradable")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@unique([symbol, chain])
  @@map("assets")
}

/// 钱包表：存储用户创建或导入的钱包
model Wallet {
  id           String        @id @default(uuid())
  /// 钱包标识，aqud + 32位Base62随机字符串，全局唯一
  identifier   String        @unique @db.VarChar(36)
  /// 钱包别名，用户自定义名称
  alias        String        @db.VarChar(64)
  /// 助记词哈希（助记词的确定性派生，用于防重复导入和密码重置验证）
  mnemonicHash String        @default("") @map("mnemonic_hash") @db.VarChar(128)
  /// 钱包来源
  source       WalletSource  @default(CREATE)
  /// 钱包密码（bcrypt hash），用于备份、删除等敏感操作的验证
  password      String        @default("") @db.VarChar(128)
  /// 密码提示，帮助用户回忆密码
  passwordHint  String    @default("") @map("password_hint") @db.VarChar(128)
  /// 备注说明
  memo         String        @default("") @db.VarChar(256)
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  @@map("wallets")
}

/// 账户资产表：每个账户持有的各资产余额
model AccountAsset {
  id        String   @id @default(uuid())
  /// 关联账户 ID
  accountId String   @map("account_id") @db.VarChar(36)
  /// 关联资产 ID
  assetId   String   @map("asset_id") @db.VarChar(36)
  /// 资产余额
  balance   Decimal  @default(0) @db.Decimal(30, 8)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([accountId, assetId])
  @@map("account_assets")
}

/// 账户表：钱包在某条链上的地址，每个钱包每条链可有多个账户（通过 index 区分）
model Account {
  id           String   @id @default(uuid())
  walletId     String   @map("wallet_id") @db.VarChar(36)
  /// 所属网络（如 Tron、Ethereum、Bitcoin）
  network      String   @db.VarChar(64)
  /// 派生路径索引，同链多账户时递增（默认0）
  index        Int      @default(0)
  /// 账户名称
  name         String   @db.VarChar(64)
  /// 链上地址（Tron格式: T+33位随机字符, EVM格式: 0x+40位hex）
  address      String   @db.VarChar(64)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@unique([walletId, network, index])
  @@map("accounts")
}

/// 钱包-设备订阅关联表：多对多关系
model WalletSubscription {
  id         Int      @id @default(autoincrement())
  /// 钱包 ID
  wallet_id  String   @db.VarChar(36)
  /// 设备 ID（devices 表的自增主键）
  device_id  Int
  /// 链标识（预留）
  chain      String   @default("") @db.VarChar(32)
  /// 地址标识（预留）
  address_id String   @default("") @db.VarChar(36)
  created_at DateTime @default(now()) @map("created_at")

  @@unique([wallet_id, device_id, chain, address_id])
  @@map("wallet_subscriptions")
}

/// 法币汇率表：存储各法币对 USDT 的兑换汇率
model FiatCurrency {
  id       String   @id @default(uuid())
  /// 货币代码，如 USD、CNY、EUR
  code     String   @unique @db.VarChar(8)
  /// 货币名称，如 US Dollar、人民币
  name     String   @db.VarChar(32)
  /// 货币符号，如 $、¥、€
  symbol   String   @db.VarChar(4)
  /// 对 USDT 的汇率
  rate     Decimal  @db.Decimal(18, 8)
  /// 小数位数
  decimals Int      @default(2)
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("fiat_currencies")
}

/// 交易记录表：存储钱包间的转账记录
model Transaction {
  id           String   @id @default(uuid())
  /// 交易哈希，链上唯一标识
  txHash       String   @unique @map("tx_hash") @db.VarChar(66)
  /// 付款链地址（Account.address，如 T.../0x...）
  fromAddress  String   @map("from_address") @db.VarChar(64)
  /// 收款链地址（始终记录，如 T.../0x...）
  toAddress    String   @map("to_address") @db.VarChar(128)
  /// 代币符号（如 USDT、TRX），直接存储便于过滤和展示
  tokenSymbol  String   @map("token_symbol") @db.VarChar(16)
  /// 交易金额
  amount       Decimal  @db.Decimal(30, 8)
  /// 手续费
  fee          Decimal  @default(0) @db.Decimal(30, 8)
  /// 交易状态
  status       TxStatus @default(PENDING)
  /// 交易备注
  memo         String   @default("") @db.VarChar(256)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("transactions")
}

/// 地址本：常用联系人地址表
model Contact {
  id        String   @id @default(uuid())
  /// 设备 ID（devices 表的自增主键）
  device_id Int
  /// 联系人名称
  name      String   @db.VarChar(64)
  /// 链上地址（Account.address，如 T.../0x.../1...）
  address   String   @db.VarChar(64)
  /// 链类型（Tron/Ethereum/Bitcoin）
  network   String   @default("Tron") @db.VarChar(64)
  /// 备注
  memo      String   @default("") @db.VarChar(256)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("contacts")
}

/// 通知/消息表：站内信通知（关联到钱包）
model Notification {
  id        String           @id @default(uuid())
  /// 关联钱包 ID
  wallet_id String           @map("wallet_id") @db.VarChar(36)
  /// 通知标题
  title     String           @db.VarChar(128)
  /// 通知内容
  content   String           @db.Text
  /// 通知类型
  type      NotificationType @map("type")
  createdAt DateTime         @default(now()) @map("created_at")

  @@map("notifications")
}

/// 通知阅读状态：每个设备对每条通知的独立阅读状态
model NotificationRead {
  id              Int      @id @default(autoincrement())
  notification_id String   @map("notification_id")
  device_id       Int      @map("device_id")
  /// 是否已读
  isRead          Boolean  @default(false) @map("is_read")
  /// 阅读时间
  readAt          DateTime? @map("read_at")
  created_at      DateTime @default(now()) @map("created_at")

  @@unique([notification_id, device_id])
  @@map("notification_reads")
}

/// 应用配置表：key-value 字典表，存储系统级配置
model AppConfig {
  id        Int      @id @default(autoincrement())
  /// 配置键名，如 server_pwd
  key       String   @unique @db.VarChar(64)
  /// 配置值
  value     String   @db.VarChar(256)
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("app_configs")
}

/// 充值记录表：管理员对系统内钱包进行代币充值的记录
model Recharge {
  id            String   @id @default(uuid())
  /// 充值目标钱包 ID
  walletId      String   @map("wallet_id") @db.VarChar(36)
  /// 钱包别名（快照）
  walletAlias   String   @map("wallet_alias") @db.VarChar(64)
  /// 钱包地址（快照）
  walletAddress String   @map("wallet_address") @db.VarChar(64)
  /// 代币符号
  tokenSymbol   String   @map("token_symbol") @db.VarChar(16)
  /// 代币名称
  tokenName     String   @map("token_name") @db.VarChar(64)
  /// 充值金额
  amount        Decimal  @db.Decimal(30, 8)
  /// 备注
  memo          String   @default("") @db.VarChar(256)
  /// 操作设备 ID（Ed25519 公钥 hex）
  deviceId      String   @map("device_id") @db.VarChar(64)
  /// 操作设备平台（ios/android/web）
  platform      String   @db.VarChar(16)
  /// App 版本号
  version       String   @default("") @db.VarChar(32)
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("recharges")
}

/// App日志表：存储客户端崩溃日志和关键业务失败日志
model AppLog {
  id         Int      @id @default(autoincrement())
  /// 设备标识（Ed25519公钥hex，崩溃时为空字符串）
  device_id  String   @default("") @db.VarChar(64)
  /// 平台：ios/android/web
  platform   String   @default("") @db.VarChar(16)
  /// App版本号
  version    String   @default("") @db.VarChar(32)
  /// 日志类型：crash=崩溃, business=关键业务失败
  log_type   String   @db.VarChar(32)
  /// 日志内容（错误消息、堆栈等）
  content    String   @db.Text
  /// 创建时间
  created_at DateTime @default(now()) @map("created_at")

  @@map("app_logs")
}