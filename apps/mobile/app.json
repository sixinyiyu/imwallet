{
  "expo": {
    "name": "AquaD",
    "slug": "aquad",
    "version": "1.2.15",
    "orientation": "portrait",
    "icon": "./assets/app_logo.png",
    "userInterfaceStyle": "light",
    "ios": {
      "bundleIdentifier": "com.aquad.app",
      "supportsTablet": true,
      "deploymentTarget": "16.4",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "AquaD 需要访问您的相机以扫描二维码"
      }
    },
    "android": {
      "package": "com.aquad.app",
      "versionCode": 124,
      "adaptiveIcon": {
        "backgroundColor": "#0A1628",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "softwareKeyboardLayoutMode": "pan"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-status-bar",
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "16.4"
          }
        }
      ],
      "./plugins/withAbiFilter",
      "./plugins/withSecureScreen",
      "expo-sqlite",
      "./plugins/withPbkdf2"
    ],
    "extra": {
      "apiBaseUrl": "https://imwallet.dpdns.org/api/v1",
      "eas": {
        "projectId": "b7ed4934-0f02-4cc5-8e21-7a0c4aba9d38"
      }
    }
  }
}